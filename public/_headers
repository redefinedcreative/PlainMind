# Cloudflare Pages headers — applied to all routes.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Permissions-Policy: geolocation=(), camera=(), microphone=(), browsing-topics=(), interest-cohort=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://app.surecontact.com; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://app.surecontact.com; frame-src https://app.surecontact.com; form-action 'self' https://app.surecontact.com; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; upgrade-insecure-requests

# Long-cache fingerprintable static assets.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
/js/*
  Cache-Control: public, max-age=86400
/styles.css
  Cache-Control: public, max-age=86400
